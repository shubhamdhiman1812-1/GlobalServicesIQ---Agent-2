
# ============================================================
# .env.example — Configuration for Emerson FSR Translation and Normalization Agent
# Copy this file to .env and fill in the required values.
# Variables marked as (pre-configured) are already set.
# ============================================================

# ══════════════════════════════════════════════════════════
# Agent Identity (PRELOADED)
# ══════════════════════════════════════════════════════════
AGENT_NAME=Emerson FSR Translation and Normalization Agent      # Agent name (pre-configured)
AGENT_ID=0677bf95-06da-4bc5-808f-f298df6952da                  # Agent unique identifier (pre-configured)
PROJECT_NAME=2004-ABA-Shubham-GlobalServicesIQ                 # Project name (pre-configured)
PROJECT_ID=23787f53-dc3f-4d3d-a4d6-73cdf82bfc8c                # Project unique identifier (pre-configured)
USE_KEY_VAULT=false                                            # Enable Azure Key Vault integration (set to true for production)
OBS_AZURE_SQL_TRUST_SERVER_CERTIFICATE=yes

# ══════════════════════════════════════════════════════════
# General Configuration
# ══════════════════════════════════════════════════════════
ENVIRONMENT=                        # Deployment environment (e.g., development, production)

# ══════════════════════════════════════════════════════════
# Azure Key Vault
# ══════════════════════════════════════════════════════════
KEY_VAULT_URI=                      # Azure Key Vault URI (e.g., https://your-vault.vault.azure.net/)
AZURE_USE_DEFAULT_CREDENTIAL=       # Use DefaultAzureCredential for Key Vault (true for managed identity, false for service principal)

# ══════════════════════════════════════════════════════════
# Azure Authentication
# ══════════════════════════════════════════════════════════
AZURE_TENANT_ID=eb06985d-06ca-4a17-81da-629ab99f6505
AZURE_CLIENT_ID=a94c622a-841c-4d61-aa48-cf611a119be6
AZURE_CLIENT_SECRET=                # Azure AD client secret (required if not using DefaultAzureCredential)

# ══════════════════════════════════════════════════════════
# LLM Configuration
# ══════════════════════════════════════════════════════════
MODEL_PROVIDER=openai
LLM_MODEL=                          # LLM model name (e.g., gpt-4.1, claude-3-opus)
LLM_TEMPERATURE=                    # Model temperature (0.0-2.0, controls randomness)
LLM_MAX_TOKENS=                     # Maximum tokens in model response

# ══════════════════════════════════════════════════════════
# API Keys / Secrets
# ══════════════════════════════════════════════════════════
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_TRANSLATOR_KEY=               # Azure Translator API key (for translation service)
ANTHROPIC_API_KEY=                  # Anthropic API key (if using Anthropic provider)
GOOGLE_API_KEY=                     # Google API key (if using Google provider)
AZURE_CONTENT_SAFETY_KEY=
OBS_AZURE_SQL_PASSWORD=

# ══════════════════════════════════════════════════════════
# Service Endpoints
# ══════════════════════════════════════════════════════════
AZURE_OPENAI_ENDPOINT=https://kb-openai-01.openai.azure.com/openai/deployments/text-embedding-ada-002/embeddings?api-version=2023-05-15
AZURE_TRANSLATOR_ENDPOINT=          # Azure Translator endpoint URL
AZURE_CONTENT_SAFETY_ENDPOINT=https://az-ai-guardrails.cognitiveservices.azure.com/
AZURE_SEARCH_ENDPOINT=              # Azure AI Search endpoint URL (for knowledge base / RAG agents)

# ══════════════════════════════════════════════════════════
# Observability
# ══════════════════════════════════════════════════════════
OBS_DATABASE_TYPE=azure_sql
OBS_AZURE_SQL_SERVER=masgenaisqlserver.database.windows.net
OBS_AZURE_SQL_DATABASE=masgenaisql
OBS_AZURE_SQL_PORT=1433
OBS_AZURE_SQL_USERNAME=saadmin
OBS_AZURE_SQL_SCHEMA=dbo

# ══════════════════════════════════════════════════════════
# Agent-Specific
# ══════════════════════════════════════════════════════════
SERVICE_NAME=                       # Service name for observability and logging
SERVICE_VERSION=                    # Service version number
VERSION=                            # Agent version (semantic version string)
VALIDATION_CONFIG_PATH=             # Path to validation_config.json (optional, for custom validation)
EMERSON_GLOSSARY_ID=                # Emerson glossary ID for translation (required for glossary-based translation)
TAXONOMY_NORMALIZATION_FUNCTION=    # Name of the normalization function for taxonomy mapping

AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=api-knowledge
